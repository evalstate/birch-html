             ivory += 1
         if r < 12 and g < 12 and b < 12:
             blackish += 1
     return {
         "palette_close_fraction": round(close / total, 4) if total else 0.0,
         "ivory_fraction": round(ivory / total, 4) if total else 0.0,
         "blackish_fraction": round(blackish / total, 4) if total else 0.0,
     }
 
 
